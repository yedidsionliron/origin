"""MatrixSorter — vectorized 3D matrix sorting utility.

Follow project coding guidelines: object-oriented, vectorized, documented,
and small surface API. This single-file implementation is a self-contained
testbed (rename to ``trial1.py`` if you want to import it).
"""

from __future__ import annotations
from typing import Any, List
import numpy as np


class MatrixSorter:
    """Sort and inspect a 3‑D array using vectorized operations.

    Public API:
    - `sort_by_dimension(dim: int) -> None` : in-place sort along axis `dim`.
    - `to_list() -> List[List[List[Any]]]` : convert internal array to plain lists.

    Args:
        matrix: 3‑D sequence (list-of-lists-of-lists) convertible to np.ndarray.
    """

    def __init__(self, matrix: List[List[List[Any]]]) -> None:
        arr = np.asarray(matrix)
        if arr.ndim != 3:
            raise ValueError("Input must be a 3-dimensional sequence")
        self.matrix: np.ndarray = arr

    def sort_by_dimension(self, dim: int) -> None:
        """In-place sort along a chosen axis (0, 1 or 2).

        Implementation: move `dim` to axis 0, call `np.sort` along axis 0,
        then invert the transpose. This provides a single vectorized sort
        path for all dimensions (no branching per-dimension).
        """
        if dim not in (0, 1, 2):
            raise ValueError("Dimension must be 0, 1 or 2.")
        perm = [dim] + [i for i in range(3) if i != dim]
        inv_perm = np.argsort(perm)
        transposed = np.transpose(self.matrix, perm)
        sorted_first = np.sort(transposed, axis=0)
        self.matrix = np.transpose(sorted_first, inv_perm)

    def to_list(self) -> List[List[List[Any]]]:
        """Return a plain Python nested-list representation of the matrix."""
        return self.matrix.tolist()

    def __repr__(self) -> str:
        return f"MatrixSorter(shape={self.matrix.shape})"


def _demo() -> None:
    """Small demonstration / smoke test for local runs."""
    mat = [
        [[3, 1, 2], [6, 5, 4]],
        [[9, 7, 8], [0, -1, -2]],
    ]
    sorter = MatrixSorter(mat)
    print("Original:")
    print(sorter.to_list())

    sorter.sort_by_dimension(2)
    print("After sorting dim=2 (each row):")
    print(sorter.to_list())

    sorter.sort_by_dimension(1)
    print("After sorting dim=1 (each layer's rows):")
    print(sorter.to_list())

    sorter.sort_by_dimension(0)
    print("After sorting dim=0 (layers sorted):")
    print(sorter.to_list())


if __name__ == "__main__":
    _demo()
